# Roadmap #30 — `logos` is a first-class value.
# A value's logos is reached with `.logos`, and logos compare by identity with `==`.

x := i32 5

same  := x.logos == i32      # true: x was built as an i32
cross := x.logos == f64      # false: i32 is not f64
meta  := i32.logos == logos  # true: a logos's own logos is the `logos` root

same and meta and not (cross)
