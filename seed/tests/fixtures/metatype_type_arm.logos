# the deep arm of the metatypefn north-star, pinned regardless of the example's
# current argument: metatype(3) yields `type`, so `a` is a TYPE VARIABLE, and the
# comptime chain's last arm fills it with the type i32 — the program's value is a
# type, printed by its spelling
metatype := fn (i:i32) -> type (
    if (i==0) (i32)
    else if (i==1) (f32)
    else if (i==2) (f64)
    else (type)
)
a : metatype(3)
if (a.type == i32) (a=9)
else if (a.type == f32 or a.type == f64) (a=9.9)
else if (a.type == type) (a=i32)
a
